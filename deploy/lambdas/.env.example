# Local deploy helper values. These are not read by the Lambda runtime.
AWS_PROFILE=default
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
PACT_IMAGE_NAME=pact-registry
PACT_FUNCTION_NAME=pact-registry

# Required Lambda runtime values.
PACT_DEPLOYMENT_MODE=aws_lambda
PACT_STORE_BACKEND=postgres
PACT_REGISTRY_URL=https://your-domain.example.com
PACT_PUBLIC_BASE_URL=https://your-domain.example.com
PACT_POSTGRES_DSN='postgresql://pact_registry_app:CHANGE_ME@your-rds-writer-endpoint.rds.amazonaws.com:5432/pact?sslmode=require'
PACT_ROOT_CERTIFICATE_PEM='-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----\n'
PACT_INTERMEDIATE_CERTIFICATE_PEM='-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----\n'
PACT_INTERMEDIATE_PRIVATE_KEY_PEM='-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n'
PACT_OPRF_SERVER_SECRET=CHANGE_ME_32_RANDOM_BYTES_BASE64URL
PACT_ADMIN_PUBLIC_JWKS='[{"kty":"EC","crv":"P-256","x":"CHANGE_ME","y":"CHANGE_ME"}]'
PACT_ALLOWED_HOSTS=your-domain.example.com

# Optional Lambda runtime values.
PACT_CORS_ORIGINS=
PACT_AUTH_PROVIDER=none
PACT_AWS_REGION=us-east-1
PACT_COGNITO_USER_POOL_ID=
PACT_COGNITO_APP_CLIENT_ID=
PACT_COGNITO_ISSUER=
PACT_COGNITO_HOSTED_UI_DOMAIN=
PACT_COGNITO_CALLBACK_URL=https://your-domain.example.com/pact/auth/callback
PACT_API_GATEWAY_BASE_PATH=/
PACT_ENABLE_WORKSPACE=true
PACT_DOCS_DIRECTORY=/var/task/docs/_build/html
PACT_LOG_LEVEL=INFO
PACT_LOG_FORMAT=json
PACT_ACCESS_LOG=true
PACT_COMMIT_SHA=

# Non-Postgres stores are mainly for local/self-hosted deployments.
PACT_FILE_STORE_DIRECTORY=
PACT_SQLITE_DATABASE=:memory:
